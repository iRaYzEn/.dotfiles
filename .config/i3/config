bindsym Mod4+minus exec mpc volume -5
bindsym Mod4+n exec mpc next
bindsym Mod4+p exec mpc prev
bindsym Mod4+f exec mpc seek +5
bindsym Mod4+b exec mpc seek -5
bindsym Mod4+space exec mpc toggle
