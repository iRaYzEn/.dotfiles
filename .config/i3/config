bindsym $mod+ctrl+n exec playerctl next --player=spotify
bindsym $mod+ctrl+p exec playerctl previous --player=spotify
bindsym $mod+ctrl+plus exec playerctl volume 0.1+ --player=spotify
bindsym $mod+ctrl+minus exec playerctl volume 0.1- --player=spotify

