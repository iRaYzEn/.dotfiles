#!/bin/bash

if [ $1 == "lap" ]; then
    xrandr  --output DP-2 --off --output eDP-1 --auto; key lap
elif [ $1 == "pc" ]; then 
    xrandr --auto; xrandr --output eDP-1 --off; xrandr --rate 165; key lap
elif [[ $1 == "both" ]]; then
    xrandr --output eDP-1 --auto --rate 60 --right-of DP-3
    xrandr --output DP-3 --primary --mode 1920x1080 --rate 165 --left-of eDP-1
fi
